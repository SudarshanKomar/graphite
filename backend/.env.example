# Graphite backend environment configuration.
# Copy to `.env` and fill in real values. Never commit `.env`.

# --- LLM provider (Gemini 2.5 Flash for dev/testing) ---
GEMINI_API_KEY=your_gemini_api_key_here
GRAPHITE_LLM_PROVIDER=gemini
GRAPHITE_LLM_MODEL=gemini-2.5-flash

# --- Data ---
# Path to the network_state/ directory (defaults to backend/network_state).
GRAPHITE_DATA_DIR=network_state

# --- API ---
GRAPHITE_API_HOST=0.0.0.0
GRAPHITE_API_PORT=8000
# Comma-separated list of allowed CORS origins for the frontend.
GRAPHITE_CORS_ORIGINS=http://localhost:3000

# --- Agent ---
GRAPHITE_AGENT_MAX_ITERATIONS=10
